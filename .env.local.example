NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=please-replace-with-32-bytes-random-base64

# Admin seed. Replace before hosting.
ADMIN_EMAIL=admin@etihadinteriors.com
ADMIN_PASSWORD=admin123

# License. In offline-first mode, the install script writes license.json.
# Optional: set a server URL to enable Envato Studio webhooks.
LICENSE_SERVER_URL=
# Optional: an RSA public key (PEM) for hardware-level license verification.
# When unset, the install script signs with LICENSE_HMAC_KEY (offline fallback).
LICENSE_PUBLIC_KEY=
LICENSE_HMAC_KEY=etihad-interiors-license-fallback-2026

# Optional: GA4
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_SITE_URL=https://studioos.studio

# Optional: Vercel Blob storage adapter.
# When BLOB_READ_WRITE_TOKEN is set, /api/upload writes through @vercel/blob.
# When unset, uploads go to /public/uploads on the local filesystem.
BLOB_READ_WRITE_TOKEN=
NEXT_PUBLIC_BLOB_PUBLIC_URL=
