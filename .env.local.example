NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=please-replace-with-32-bytes-random-base64

# Admin seed. Replace before hosting.
ADMIN_EMAIL=admin@etihadinteriors.com
ADMIN_PASSWORD=admin123

# License. In offline-first mode, the install script writes license.json.
# Optional: set a server URL to enable Envato Studio webhooks.
LICENSE_SERVER_URL=
# Optional: an RSA public key (PEM) for hardware-level license verification.
# When unset, the install script signs with LICENSE_HMAC_KEY (offline fallback).
LICENSE_PUBLIC_KEY=
LICENSE_HMAC_KEY=please-replace-with-32-bytes-random-hex

# Studio demo auto-stamp (postinstall). Override to bind a different
# domain/tier to the demo. Without overrides the script defaults to the
# canonical studio host listed below. Requires LICENSE_HMAC_KEY above.
STAMP_HOST=ethinterior.vercel.app
STAMP_TIER=business
STAMP_DAYS_VALID=365
STAMP_PURCHASE_CODE=ELITE-MARCH-2026

# Operator console (studio-only, gated by SUPERADMIN_EMAIL/PASSWORD).
# Different from ADMIN_EMAIL/PASSWORD. Buyers never see these.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Envato webhook (server-to-server). Optional but recommended for sales on Envato.
ENVATO_WEBHOOK_SECRET=

# Optional: GA4
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_SITE_URL=https://ethinterior.vercel.app

# Optional: Vercel Blob storage adapter.
# When BLOB_READ_WRITE_TOKEN is set, /api/upload writes through @vercel/blob.
# When unset, uploads go to /public/uploads on the local filesystem.
BLOB_READ_WRITE_TOKEN=
NEXT_PUBLIC_BLOB_PUBLIC_URL=
